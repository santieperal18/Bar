# ============================================
# VARIABLES DE ENTORNO - COPIA Y RENOMBRA A .env
# ============================================

# -------- BASE DE DATOS --------
# Para DESARROLLO (SQLite - local)
# DB_DIALECT=sqlite
# DB_STORAGE=./data/restoBar.db

# Para PRODUCCIÓN (PostgreSQL)
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=resto_bar_db
DB_USER=postgres
DB_PASSWORD=tu_contraseña_segura
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2

# -------- SEGURIDAD JWT --------
JWT_SECRET=tu_clave_secreta_muy_segura_cambiar_en_produccion_minimo_32_caracteres
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=tu_clave_refresh_muy_segura_cambiar_en_produccion_minimo_32_caracteres
JWT_REFRESH_EXPIRES_IN=7d

# -------- SERVIDOR --------
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://tudominio.com

# -------- RATE LIMITING --------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------- LOGS --------
LOG_LEVEL=info

# -------- ADMIN CREDENTIALS --------
ADMIN_USERNAME=main
ADMIN_PASSWORD=main123
